NEXT_PUBLIC_API_URL=http://localhost:5100/api
NEXT_PUBLIC_APP_NAME=EasyFix CRM

# QuickSight bridge (header button) — env-specific base URLs. The
# navbar's openQuickSight() picks the prod URL when NODE_ENV=production
# and falls back to the QA URL otherwise. Token is minted server-side
# (see EasyFix_Backend /admin/quicksight/token).
NEXT_PUBLIC_QA_QUICKSIGHT_URL=https://uat.easyfix.in
NEXT_PUBLIC_PROD_QUICKSIGHT_URL=https://corporates.core.easyfix.in
